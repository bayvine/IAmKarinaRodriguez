{
  "format": "custom",
  "id": "global_nav",
  "json": {
    "Main": {
      "header_logo": {
        "type": "Image",
        "config": {
          "label": "Header Logo",
          "constraint": {
            "width": 800,
            "height": 300
          },
          "thumbnails": []
        }
      },
      "header_brand_name": {
        "type": "Text",
        "config": {
          "label": "Header Brand Name",
          "placeholder": "Karina Rodriguez"
        }
      },
      "seo_site_name": {
        "type": "Text",
        "config": {
          "label": "SEO Site Name",
          "placeholder": "I Am Karina Rodriguez"
        }
      },
      "seo_default_description": {
        "type": "Text",
        "config": {
          "label": "SEO Default Description",
          "placeholder": "Executive coaching, leadership development, and resilience support for high-performing leaders in Denver."
        }
      },
      "seo_default_image": {
        "type": "Image",
        "config": {
          "label": "SEO Default Image",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      },
      "navigation_links": {
        "type": "Group",
        "config": {
          "label": "Navigation Links",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "Label",
                "placeholder": "About"
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link",
                "placeholder": "",
                "select": null,
                "allowText": true,
                "allowTargetBlank": true
              }
            }
          }
        }
      },
      "primary_cta_label": {
        "type": "Text",
        "config": {
          "label": "Primary CTA Label",
          "placeholder": "Free Discovery Call"
        }
      },
      "primary_cta_link": {
        "type": "Link",
        "config": {
          "label": "Primary CTA Link",
          "placeholder": "",
          "select": null,
          "allowText": true,
          "allowTargetBlank": true
        }
      },
      "contact_email": {
        "type": "Text",
        "config": {
          "label": "Contact Email",
          "placeholder": "hello@karinarodriguez.com"
        }
      },
      "contact_phone": {
        "type": "Text",
        "config": {
          "label": "Contact Phone",
          "placeholder": "(303) 555-1234"
        }
      },
      "social_links": {
        "type": "Group",
        "config": {
          "label": "Social Links",
          "repeat": true,
          "fields": {
            "platform": {
              "type": "Select",
              "config": {
                "label": "Platform",
                "placeholder": "Choose a platform",
                "options": [
                  "instagram",
                  "linkedin",
                  "tiktok",
                  "youtube",
                  "facebook",
                  "x"
                ]
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link",
                "placeholder": "",
                "select": null,
                "allowText": true,
                "allowTargetBlank": true
              }
            }
          }
        }
      }
    }
  },
  "label": "Global Nav",
  "repeatable": false,
  "status": true
}
