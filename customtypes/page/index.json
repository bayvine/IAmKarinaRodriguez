{
  "format": "page",
  "id": "page",
  "label": "Page",
  "repeatable": true,
  "status": true,
  "json": {
    "Page Settings": {
      "page_title": {
        "type": "Text",
        "config": {
          "label": "Page Title",
          "placeholder": "Executive Coaching in Denver"
        }
      }
    },
    "Main": {
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "hero": {
              "type": "SharedSlice"
            },
            "centered_statement": {
              "type": "SharedSlice"
            },
            "event_highlight": {
              "type": "SharedSlice"
            },
            "faq": {
              "type": "SharedSlice"
            },
            "checklist_feature": {
              "type": "SharedSlice"
            },
            "checklist_spotlight": {
              "type": "SharedSlice"
            },
            "media_highlight": {
              "type": "SharedSlice"
            },
            "process_steps": {
              "type": "SharedSlice"
            },
            "profile_feature": {
              "type": "SharedSlice"
            },
            "rich_text_content": {
              "type": "SharedSlice"
            },
            "testimonials_showcase": {
              "type": "SharedSlice"
            },
            "services_showcase": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "config": {
          "label": "Meta Title",
          "placeholder": "Executive Coaching in Denver | Karina Rodriguez"
        },
        "type": "Text"
      },
      "meta_description": {
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        },
        "type": "Text"
      },
      "meta_image": {
        "config": {
          "constraint": {
            "height": 1260,
            "width": 2400
          },
          "label": "Meta Image",
          "thumbnails": []
        },
        "type": "Image"
      }
    }
  }
}
