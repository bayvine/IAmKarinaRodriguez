{
  "id": "rich_text_content",
  "type": "SharedSlice",
  "name": "RichTextContent",
  "description": "Rich Text Content",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "section_id": {
          "type": "Text",
          "config": {
            "label": "Section ID",
            "placeholder": "content"
          }
        },
        "theme": {
          "type": "Select",
          "config": {
            "label": "Theme",
            "placeholder": "Choose a theme",
            "options": [
              "light",
              "dark"
            ]
          }
        },
        "image_position": {
          "type": "Select",
          "config": {
            "label": "Image Position",
            "placeholder": "Choose an image position",
            "options": [
              "right",
              "left"
            ]
          }
        },
        "label": {
          "type": "Text",
          "config": {
            "label": "Label",
            "placeholder": "Eyebrow Here"
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Title of Section",
            "allowTargetBlank": true,
            "multi": "heading1,heading2,heading3,heading4,strong,em",
            "labels": []
          }
        },
        "body": {
          "type": "StructuredText",
          "config": {
            "label": "Body",
            "placeholder": "Use this slice for longer-form page content.",
            "allowTargetBlank": true,
            "multi": "heading2,heading3,heading4,paragraph,strong,em,hyperlink,list-item,o-list-item",
            "labels": []
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Image",
            "constraint": {
              "width": 1800,
              "height": 2200
            },
            "thumbnails": []
          }
        }
      },
      "items": {}
    }
  ]
}
