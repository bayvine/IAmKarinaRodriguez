{
  "id": "media_gallery",
  "type": "SharedSlice",
  "name": "MediaGallery",
  "description": "Media Gallery",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "section_id": {
          "type": "Text",
          "config": {
            "label": "Section ID",
            "placeholder": "media-gallery"
          }
        },
        "theme": {
          "type": "Select",
          "config": {
            "label": "Theme",
            "placeholder": "Choose a theme",
            "options": [
              "light",
              "dark"
            ]
          }
        },
        "layout": {
          "type": "Select",
          "config": {
            "label": "Layout",
            "placeholder": "Choose a layout",
            "options": [
              "auto",
              "single",
              "two-up"
            ]
          }
        },
        "label": {
          "type": "Text",
          "config": {
            "label": "Label",
            "placeholder": "Eyebrow Here"
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Optional section title",
            "allowTargetBlank": true,
            "multi": "heading1,heading2,heading3,heading4,strong,em",
            "labels": []
          }
        },
        "body": {
          "type": "StructuredText",
          "config": {
            "label": "Body",
            "placeholder": "Optional intro text above the gallery.",
            "allowTargetBlank": true,
            "multi": "heading2,heading3,heading4,paragraph,strong,em,hyperlink,list-item,o-list-item",
            "labels": []
          }
        }
      },
      "items": {
        "media": {
          "type": "Link",
          "config": {
            "label": "Media",
            "placeholder": "",
            "select": "media",
            "allowText": true
          }
        },
        "image": {
          "type": "Image",
          "config": {
            "label": "Image",
            "constraint": {
              "width": 1800,
              "height": 1350
            },
            "thumbnails": []
          }
        },
        "caption": {
          "type": "StructuredText",
          "config": {
            "label": "Caption",
            "placeholder": "Optional caption or supporting text.",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
            "labels": []
          }
        }
      }
    }
  ]
}
