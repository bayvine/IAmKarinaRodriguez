        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "A Section Title Right Here.",
            "allowTargetBlank": true,
            "multi": "heading1,heading2,heading3,heading4,strong,em",
            "labels": []
          }
        },
        "intro_body": {
          "type": "StructuredText",
          "config": {
            "label": "Intro Body",
            "placeholder": "Use this for the text above the media.",
            "allowTargetBlank": true,
            "multi": "heading2,heading3,heading4,paragraph,strong,em,hyperlink,list-item,o-list-item",
            "labels": []
          }
        },
        "bottom_body": {
          "type": "StructuredText",
          "config": {
            "label": "Bottom Body",
            "placeholder": "Use this for the text below the media.",
            "allowTargetBlank": true,
            "multi": "heading2,heading3,heading4,paragraph,strong,em,hyperlink,list-item,o-list-item",
            "labels": []
          }
        }
      },
      "items": {
