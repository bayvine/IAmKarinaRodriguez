{
  "id": "faq",
  "type": "SharedSlice",
  "name": "Faq",
  "description": "FAQ",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "docURL": "...",
      "version": "initial",
      "description": "Default",
      "imageUrl": "",
      "primary": {
        "section_id": {
          "type": "Text",
          "config": {
            "label": "Section ID",
            "placeholder": "faq"
          }
        },
        "theme": {
          "type": "Select",
          "config": {
            "label": "Theme",
            "placeholder": "Choose a theme",
            "options": [
              "light",
              "dark"
            ]
          }
        },
        "label": {
          "type": "Text",
          "config": {
            "label": "Label",
            "placeholder": "FAQ"
          }
        },
        "title": {
          "type": "StructuredText",
          "config": {
            "label": "Title",
            "placeholder": "Questions people often ask",
            "allowTargetBlank": true,
            "multi": "heading1,heading2,heading3,heading4,strong,em",
            "labels": []
          }
        },
        "intro": {
          "type": "StructuredText",
          "config": {
            "label": "Intro",
            "placeholder": "A short introduction to the FAQ section.",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
            "labels": []
          }
        }
      },
      "items": {
        "question": {
          "type": "Text",
          "config": {
            "label": "Question",
            "placeholder": "What does an executive coach do?"
          }
        },
        "answer": {
          "type": "StructuredText",
          "config": {
            "label": "Answer",
            "placeholder": "An executive coach helps leaders think more clearly, navigate challenges more effectively, and grow in how they lead.",
            "allowTargetBlank": true,
            "multi": "paragraph,strong,em,hyperlink,list-item,o-list-item",
            "labels": []
          }
        }
      }
    }
  ]
}